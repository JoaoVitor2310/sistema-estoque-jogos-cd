#!/bin/sh
# Hook executado antes de cada commit.
# Verifica se o código está formatado conforme o Pint.

# GUI clients (VS Code, etc.) rodam hooks com PATH mínimo — sem acesso ao PHP.
# Esta linha garante que os binários do sistema sejam encontrados.
export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

if [ ! -f "./vendor/bin/pint" ]; then
  echo "⚠️  Pint not found. Run: composer install"
  exit 1
fi

echo "🔍 Checking code formatting with Pint..."

# Se PHP estiver disponível no PATH, usa diretamente (CI, produção, máquinas com PHP nativo).
# Caso contrário, tenta via container Docker (ambiente de desenvolvimento com PHP no Docker).
if command -v php > /dev/null 2>&1; then
  ./vendor/bin/pint --test
elif docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^app-cd$'; then
  docker exec app-cd ./vendor/bin/pint --test
else
  echo "⚠️  PHP not found and container 'app-cd' is not running. Skipping Pint check."
  exit 0
fi

PINT_EXIT=$?

if [ $PINT_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Code is not properly formatted."
  echo "   Fix it and commit again:"
  echo ""
  echo "     ./vendor/bin/pint"
  echo "     # or, if using Docker:"
  echo "     docker exec app-cd ./vendor/bin/pint"
  echo ""
  exit 1
fi

exit 0
